<% 
    appointments = [
      FactoryBot.build(:aeon_appointment, id: 1, start_time: Time.zone.now + 8.days, requests: 5.times.map { FactoryBot.build(:aeon_request) }),
      FactoryBot.build(:aeon_appointment, id: 2, start_time: Time.zone.now + 12.days, requests: [FactoryBot.build(:aeon_request)]),
      FactoryBot.build(:aeon_appointment, id: 3, start_time: Time.zone.now + 32.days)
    ]

%>
<form id="reading-accordion">
  <ul id="reading" class="appointments-container list-unstyled selected-items-container">
    <%= 
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1',
        appointments: appointments
      ) %>


    <%= 
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 2',
        dom_id: 'item_2',
        appointments: appointments
      ) %>
  </ul>
</form>

<hr>

<form id="reading-accordion2">
  <ul id="reading2" class="appointments-container list-unstyled selected-items-container">
    <%=
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1',
        appointments: appointments
      ) %>
  </ul>
</form>

<hr>


<form id="digitized-accordion">
  <ul class="accordion digitization-accordion selected-items-container px-0">
    <%=
      render Aeon::DigitizationFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1'
      ) %>

    <%=
      render Aeon::DigitizationFormItemComponent.new(
        title: 'Item 2',
        dom_id: 'item_2'
      ) %>
  </ul>
</form>

<hr>

<form id="digitized-accordion2">
  <ul class="accordion digitization-accordion selected-items-container px-0">
    <%=
      render Aeon::DigitizationFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1'
      ) %>
  </ul>
</form>
