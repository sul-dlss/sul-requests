<% 
    appointments = [
      FactoryBot.build(:aeon_appointment, id: 1, start_time: Time.zone.now + 8.days, requests: 5.times.map { FactoryBot.build(:aeon_request) }),
      FactoryBot.build(:aeon_appointment, id: 2, start_time: Time.zone.now + 12.days, requests: [FactoryBot.build(:aeon_request)]),
      FactoryBot.build(:aeon_appointment, id: 3, start_time: Time.zone.now + 32.days)
    ]

%>
<form id="reading-accordion" class="col-lg-9">
  <ul id="reading" class="appointments-container list-unstyled selected-items-container">
    <%= 
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1',
        appointments: appointments
      ) %>


    <%= 
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 2',
        dom_id: 'item_2',
        appointments: appointments
      ) %>
  </ul>
</form>


<form id="reading-accordion2" class="col-lg-9">
  <ul id="reading2" class="appointments-container list-unstyled selected-items-container">
    <%=
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1',
        appointments: appointments
      ) %>
  </ul>
</form>


<form id="reading-accordion3" class="col-lg-9 selected-items-container">
  <div class="save-for-later border rounded p-3 mb-3">
    <h3 class="h4 text-cardinal"><i class="bi bi-pin-angle-fill me-2 text-digital-red"></i>Save for later</h3>
    <ul class="list-unstyled mb-0" data-save-for-later-target="list">
      <li class="saved-item">Saved for later item</li>
    </ul>
  </div>

  <ul id="reading3" class="appointments-container list-unstyled">
    <%=
      render Aeon::AppointmentFormItemComponent.new(
        title: 'Item 1',
        dom_id: 'item_1',
        appointments: appointments
      ) %>
  </ul>
</form>
