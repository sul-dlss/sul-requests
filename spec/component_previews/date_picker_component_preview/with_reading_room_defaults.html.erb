<% reading_room = FactoryBot.build(:aeon_reading_room, closures: [Aeon::ReadingRoomClosures.new(start_date: Time.current.next_week(:monday).beginning_of_day, end_date: Time.current.next_week(:monday).end_of_day)]) %>
<%= form_with(model: Aeon::Appointment.new, url: '#') do |f| %>
  <%= render DatePickerComponent.new(:date, form: f, schedule: Aeon::AppointmentSchedule.new(reading_room: reading_room)) %>
<% end %>
