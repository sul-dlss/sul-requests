<turbo-frame id="aeon-requests-frame">
  <button type="button" class="btn-close float-end mt-2 d-block d-lg-none" data-bs-toggle="offcanvas" data-bs-target="#draft_aeon_requests_sidebar" aria-label="Close"></button>
  <h2 class="h3 text-center mb-3">
    <i class="bi bi-pin-angle-fill me-1"></i>Saved for later
    <div class="fw-semibold text-center fs-6 mt-1">Items requested for reading room use</div>
  </h2>
  <p class="text-center text-digital-red"><i class="bi bi-exclamation-triangle-fill me-1"></i> Materials are unavailable until an appointment is scheduled.</p>

  <div id="aeon-requests">
    <%= render Aeon::RequestGroupBriefComponent.with_collection(@aeon_request_groups, after_request_item_component: SidebarAppointmentDropdownComponent) %>
  </div>
</turbo-frame>
