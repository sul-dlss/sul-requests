<%= turbo_frame_tag params[:modal] do %>
  <%= render ModalComponent.new(id: params[:modal],
                                cancel_text: 'Cancel',
                                submit_text: 'Submit') do |component| %>
    <% component.with_title.with_content('Edit request') %>
    <% component.with_prepend_body do %>
      <%= render RecordHeaderCardComponent.new(record: @aeon_request, classes: 'mb-0 bg-light rounded-0 border-bottom') %>
    <% end %>
    <% component.with_body do %>
      <%= render 'form' %>
    <% end %>
  <% end %>
<% end %>
