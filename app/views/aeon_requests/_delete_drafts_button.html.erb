<div class="dropdown">
  <button class="btn btn-sm btn-delete" type="button" disabled aria-expanded="false"
    data-request-bulk-delete-target="deleteButton" data-action="request-bulk-delete#openDeleteModal" id="delete-all">
    <i class="bi bi-trash me-1"></i> Delete selected (<span class="count">0</span>)
  </button>
  <div class="mt-2 d-flex justify-content-end">
    <span>
      <input type="checkbox" name="select-all-delete" id="select-all-delete" class="me-1 form-check-input" data-request-bulk-delete-target="selectall" data-action="change->request-bulk-delete#toggleSelectAll">
      <%= label_tag 'select-all-delete', 'Select all', class: 'form-check-label small' %>
    </span>
  </div>
</div>
