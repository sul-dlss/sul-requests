<div class="container" data-controller="draft-request">
  <div class="row">
    <div class="col-8 pe-5">
      <div class="d-flex flex-wrap gap-2 justify-content-between mb-3">
        <h1>Draft requests</h1>
        <div class="d-flex flex-wrap gap-2">
          <%= render 'sort_dropdown' %>
          <%= render 'filter_dropdown' %>
          <%= render 'delete_drafts_button' %>
        </div>
      </div>

      <% @aeon_request_groups.each do |requests_in_group| %>
        <% if requests_in_group.one? && !requests_in_group.first.multi_item_selector? %>
          <%= render Aeon::RequestComponent.new(request: requests_in_group.first) %>
        <% else %>
          <%= render Aeon::RequestGroupComponent.new(request_group: requests_in_group) %>
        <% end %>
      <% end %>
    </div>
    <div class="col-4">
      <turbo-frame src="<%= aeon_appointments_path(variant: 'sidebar') %>" id="aeon-appointments" class="d-block" data-turbo="false">
        <div class="d-flex align-items-center justify-content-center" style="height: 200px;">
          <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>
      </turbo-frame>
    </div>
  </div>
  <div class="modal fade" id="delete-bulk" tabindex="-1" aria-labelledby="title-delete-bulk" aria-hidden="true" data-draft-request-target="deleteModal">
    <div class="modal-lg modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title" id="title-delete-bulk">Delete draft requests?</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body fw-normal">
            <% @aeon_request_groups.each do |group| %>
              <div hidden data-draft-request-target="modalGroup" data-digital="<%= group.digital? %>"
                <% unless group.first.multi_item_selector? %>data-request-id="<%= group.first.id %>"<% end %>>
                <%= render Aeon::RequestGroupCompactComponent.new(request_group: group) %>
              </div>
            <% end %>
            <div hidden data-draft-request-target="modalSummary"></div>
          </div>
          <div class="p-3 m-0 bg-info-subtle fw-semibold">
            This action cannot be undone.
          </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">No</button>
          <%= form_with url: destroy_multiple_aeon_requests_path, method: 'delete', data: { 'draft-request-target': 'deleteForm' } do %>
            <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">Yes - Delete</button>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
