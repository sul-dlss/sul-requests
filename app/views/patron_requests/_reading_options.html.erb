<div class="row p-3 gap-3 flex-column flex-md-row" data-controller="view-container-contents">
  <% appointments = current_user.aeon.appointments_for(site: f.object.aeon_site) %>
  <div id="new-appt-alert">
    <% if appointments.blank? %>
      <div class="alert alert-warning alert-dismissible shadow-sm d-flex align-items-center">
        <div role="img" aria-label="Warning icon" class="text-warning bi bi-exclamation-triangle-fill fs-3 me-3"></div>
        <div class="text-body">
          <div>You don’t have any appointments yet. Create one to continue.</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
  </div>

  <%= render Aeon::ReadingRoomBriefComponent.new(reading_room: f.object.aeon_reading_room) %>

  <div class="mt-3">
    <ul class="appointments-container list-unstyled selected-items-container" data-item-selector-target="selectedItems" data-template="#appointmentTemplate">
      <% if f.object.selectable_items.one? %>
        <%= render Aeon::AppointmentFormItemComponent.new(title: f.object.selectable_items.first.callnumber, dom_id: f.object.selectable_items.first.id, base_name: "patron_request[aeon_item][#{f.object.selectable_items.first.id}]", appointments: appointments) %>
      <% end %>
    </ul>

    <template id="appointmentTemplate">
      <%= render Aeon::AppointmentFormItemComponent.new(title: '__TITLE__', dom_id: '__ID__', base_name: 'patron_request[aeon_item][__ID__]', reading_room_id: f.object.aeon_reading_room.id, appointments: appointments) %>
    </template>
  </div>

  <div class="mt-3 mb-2" data-controller="char-counter">
    <%= f.label :aeon_reading_special, 'Additional information', :class => 'fw-bold py-2' %>
    <%= f.text_area :aeon_reading_special, :class => 'form-control', rows: 3, maxlength: 255, data: { action: "input->char-counter#updateCharCounter"} %>
    <p class="form-text text-secondary d-flex justify-content-between">
      <span>Limit 255 characters.</span>
      <span data-char-counter-target="counter"></span>
    </p>
  </div>

  <!-- View container contents modal -->
  <%= render ModalComponent.new(id: "view-container-contents", data: {view_container_contents_target: "viewModal"}) do |component| %>
    <% component.with_title.with_content('Contents') %>
    <% component.with_body(classes: []) do %>
      <div data-view-container-contents-target="banner" class="banner"></div>
      <div class="modal-body" data-view-container-contents-target="contents">
        Body goes here
    <% end %>
  <% end %>
</div>
