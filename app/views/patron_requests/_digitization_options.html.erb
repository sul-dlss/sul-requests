<div class="row p-3 gap-3 flex-column flex-md-row">
  <%= render 'digitization_notice' %>

  <div class="accordion digitization-accordion selected-items-container" data-patron-request-target="digitizationItems" data-item-selector-target="selectedItems" data-template="#digitizationTemplate">
    <% if f.object.selectable_items.one? %>
      <span class="text-black fw-semibold selected-item-title stretched-link"><%= f.object.selectable_items.first.callnumber %></span>
      <%= render Aeon::DigitizationFormItemComponent.new(base_name: "patron_request[aeon_item][#{f.object.selectable_items.first.id}]") %>
    <% end %>
  </div>

  <template id="digitizationTemplate">
    <%= render Aeon::DigitizationFormAccordionComponent.new(title: '__TITLE__', dom_id: '__ID__', base_name: 'patron_request[aeon_item][__ID__]') %>
  </template>
</div>
