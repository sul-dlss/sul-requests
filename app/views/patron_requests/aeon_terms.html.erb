<%= render 'aeon_users/terms_text' %>

<%= form_with url: accept_terms_aeon_user_path(referer: request.url), method: :post do |f| %>

  <div class="my-3 px-3 py-2 bg-danger-subtle d-flex flex-row justify-content-start align-items-baseline gap-2">
    <%= f.check_box :aeon_terms, required: true %>
    <div>
      <%= f.label "aeon_terms", 'I agree to these terms', class:'fw-bold redesign-required-label d-block' %>
      By checking this box, you acknowledge and agree to comply with the policies and regulations above.
    </div>
  </div>

  <div class="d-flex justify-content-end">
    <%= f.submit 'Continue' %> 
  </div>
<% end %>
