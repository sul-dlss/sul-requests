<div class="p-3 pt-0">
    <% if f.object.mediateable? %>
        <%= f.label :needed_date, 'I plan to visit on:', class: 'required-label py-2' %>
        <%= render DatePickerComponent.new(:needed_date, form: f,
                schedule: DatePicker::LibrarySchedule.new(library: f.object.pickup_service_point.library,
                                                         min: f.object.earliest_delivery_estimate['date']),
                data: { action: 'change->accordion-form#reenableNextButtons' }) %>
    <% else %>
        <%= f.label :needed_date, 'Not needed after', class: 'required-label py-2' %>
        <%= f.date_field :needed_date, required: true, min: Date.today, value: Time.zone.today + 1.year, class: 'form-control' %>
    <% end %>
</div>
