<div class="dropdown sidebar-custom-select" data-reading-room-id="<%= reading_room_id %>">
  <% spinner = capture do %>
    <div class="text-green submit-message align-content-center" data-submit-message-target="message">
      <div class="spinner-border spinner-border-sm me-2" aria-hidden="true"></div><span>Scheduling</span>
    </div>
  <% end %>
  <%= button_tag 'Appointment', class: 'dropdown-toggle btn btn-link su-underline p-0', type: 'button', data: { bs_toggle: 'dropdown', 'appointment-select-submit-target': 'button', turbo_submits_with: spinner }, aria: { expanded: false  }, disabled: appointments.blank? %>
  <menu class="dropdown-menu sidebar-appt-dropdown">
    <li></li>
    <%= render Aeon::AppointmentOptionComponent.with_collection(appointments, name: 'aeon_request[appointment_id]', data_action: nil) %>
  </menu>
</div>
