<%= turbo_frame_tag params[:modal] do %>
  <%= form_with(url: update_multiple_aeon_requests_path) do |f| %>
    <%= hidden_field_tag :appointment_id, @appointment.id %>

    <div class="modal-header">
      <div class="d-flex flex-column flex-grow-1">
        <div class="d-flex justify-content-between mb-2">
          <h1 class="mb-0">Add items</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="d-flex flex-row justify-content-between align-items-center">
          <div class="d-flex flex-row gap-2 fw-semibold">
            <%= render Aeon::AppointmentDateTimeComponent.new(appointment: @appointment, location: @appointment.reading_room.name) %>
          </div>
          <div><%= render Aeon::AppointmentLimitComponent.from_appointment(@appointment, data: { action: 'items-updated@window->progress-bar#updateCount' }) %></div>
        </div>
      </div>
    </div>
    <div class="modal-body">
      <div class="accordion mb-2" id="appointmentRequestsAccordion">
        <div class="accordion-item">
          <h2 class="accordion-header">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#appointmentRequests" aria-expanded="false" aria-controls="appointmentRequests">
              <span class="fs-5 fw-semibold">Items scheduled to use during this appointment</span>
              <i class="bi bi-chevron-down accordion-header-icon ms-auto"></i>
            </button>
          </h2>
          <div id="appointmentRequests" class="accordion-collapse collapse" data-bs-parent="#appointmentRequestsAccordion">
            <template>
              <%= render Aeon::RemoveRequestComponent.new(request: Aeon::Request.new(transaction_number: '__TRANSACTION_NUMBER__', item_title: '__ITEM_TITLE__')) %>
            </template>
            <div class="accordion-body p-0">
              <div class="hidden-if-peers p-3">No items have been requested for this appointment.</div>
              <%= render Aeon::RequestGroupBriefComponent.with_collection(@appointment.grouped_requests,
                                                                          classes: %w[request-group border-top mb-0 p-3],
                                                                          data: { controller: 'add-items', appointment_target: '#appointmentRequests' },
                                                                          after_request_item_component: Aeon::RemoveRequestComponent) %>
            </div>
          </div>
        </div>
      </div>
      <div class="accordion" id="savedForLaterRequestsAccordion">
        <div class="accordion-item">
          <h2 class="accordion-header">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#savedForLaterRequests" aria-expanded="true" aria-controls="savedForLaterRequests">
              <span class="d-flex flex-wrap column-gap-2 align-items-center">
                <span class="fs-5 fw-semibold"><i class="bi bi-pin-angle-fill me-1"></i>Saved for later</span>
                <span style="margin-top: .15rem">Only materials associated with <%= @appointment.reading_room.name %> are eligible to add</span>
              </span>
              <i class="bi bi-chevron-down accordion-header-icon ms-auto"></i>
            </button>
          </h2>
          <div id="savedForLaterRequests" class="accordion-collapse collapse show" data-bs-parent="#savedForLaterRequestsAccordion">
            <template>
              <%= render Aeon::AddRequestComponent.new(request: Aeon::Request.new(transaction_number: '__TRANSACTION_NUMBER__', item_title: '__ITEM_TITLE__')) %>
            </template>
            <div class="accordion-body p-0">
              <div class="hidden-if-peers p-3">No items eligible for this appointment.</div>
              <%= render Aeon::RequestGroupBriefComponent.with_collection(@aeon_request_groups,
                                                                          classes: %w[request-group border-top mb-0 p-3],
                                                                          data: { controller: 'add-items', appointment_target: '#appointmentRequests' },
                                                                          after_request_item_component: Aeon::AddRequestComponent) %>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">Cancel</button>
      <%= f.submit "Save changes", class: 'btn btn-primary', data: { bs_dismiss: 'modal' } %>
    </div>
  <% end %>
<% end %>
