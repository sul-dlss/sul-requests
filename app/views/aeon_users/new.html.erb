<%= form_with(url: aeon_users_path, method: 'POST', html: { class: 'accordion', id: 'aeon-user' }, data: { controller: 'accordion-form' }) do |f| %>
  <%= f.hidden_field :referrer, value: params[:referrer] %>

  <%= render AccordionStepComponent.new(
      id: 'step-1',
      step_index: 1,
      form_id: 'aeon-user'
    ) do |component| %>
      <% component.with_title.with_content('Account information') %>
      <% component.with_body do %>
        <div>
          <%= f.label :name, class: 'form-label fw-semibold redesign-required-label' %>
          <%= f.text_field :name, value: current_user.name, class: 'form-control', required: true %>
        </div>
        <div class="mt-2">
          <%= f.label :email_address, class: 'form-label fw-semibold redesign-required-label' %>
          <%= f.text_field :email_address, value: current_user.email_address, class: 'form-control', required: true %>
        </div>
        <div class="mt-2">
          <%= f.label :phone, class: 'form-label fw-semibold' %>
          <%= f.text_field :phone, class: 'form-control' %>
        </div>
        <div class="mt-2">
          <%= f.label :address_1, class: 'form-label fw-semibold redesign-required-label' %>
          <%= f.text_field :address_1, class: 'form-control', required: true %>
        </div>
        <div class="mt-2">
          <%= f.label :address_2, class: 'form-label fw-semibold' %>
          <%= f.text_field :address_2, class: 'form-control' %>
        </div>
        <div class="mt-2">
          <%= f.label :city, class: 'form-label fw-semibold redesign-required-label' %>
          <%= f.text_field :city, class: 'form-control', required: true %>
        </div>
        <div class="row mt-2">
          <div class="col-8">
            <%= f.label :state_or_province, class: 'form-label fw-semibold redesign-required-label' %>
            <%= f.text_field :state_or_province, class: 'form-control', required: true %>
          </div>
          <div class="col-4">
            <%= f.label :zip_code, class: 'form-label fw-semibold redesign-required-label' %>
            <%= f.text_field :zip_code, class: 'form-control', required: true %>
          </div>
        </div>
        <div class="mt-2">
          <%= f.label :country, class: 'form-label fw-semibold redesign-required-label' %>
          <%= f.text_field :country, class: 'form-control', required: true %>
        </div>
      <% end %>
  <% end %>
  <%= render AccordionStepComponent.new(
      id: 'step-2',
      step_index: 2,
      form_id: 'aeon-user',
      submit: true,
      cancel: false
    ) do |component| %>
      <% component.with_title.with_content('Terms') %>
      <% component.with_body do %>
        <%= render 'terms_text' %>
        <div class="mt-2 px-3 py-2 bg-light d-flex flex-row justify-content-start align-items-baseline gap-2">
          <%= f.check_box :aeon_terms, { data: { required: true } }, 1, nil %>
          <div>
            <%= f.label "aeon_terms", 'I agree to these terms', class:'fw-bold redesign-required-label d-block' %>
            By checking this box, you acknowledge and agree to comply with the policies and regulations above.
          </div>
        </div>
      <% end %>
  <% end %>
<% end %>
