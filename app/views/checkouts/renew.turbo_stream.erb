<%= turbo_stream.replace(dom_id(@response.checkout)) do %>
  <% if @response.success? %>
    <%= render Folio::CheckoutComponent.new(checkout: @response.updated_checkout, patron: patron_or_group, renewal_view: true) %>
  <% else %>
    <%= render Folio::CheckoutComponent.new(checkout: @response.checkout, patron: patron_or_group) %>
  <% end %>
<% end %>

<%= turbo_stream.replace('renew-all-button') do %>
  <%= render 'checkouts/renew_all_button' %>
<% end %>

<%= turbo_stream.prepend_all('.checkouts-list') do %>
  <% error = I18n.t('mylibrary.renew_item.error_html', title: @response.checkout.title) %>
  <%= render 'shared/flashes', flash: { error: error}, classes: '' %>
<% end unless @response.success? %>
