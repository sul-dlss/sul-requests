<div id="renew-all-button">
  <% if @checkouts.any?(&:renewable?) %>
    <% if patron_or_group.can_renew? %>
        <% renewable_count = @checkouts.count(&:renewable?) %>
        <%= form_tag renew_eligible_checkouts_path, method: :post do %>
          <%= button_tag class: 'btn btn-primary btn-sm text-nowrap',
                          data: { turbo_submits_with: t('mylibrary.renew_all_items.in_progress_html', count: renewable_count) },
                          onclick: 'window.dispatchEvent(new CustomEvent("renew-all"))',
                          type: 'submit' do %>
            <i class="bi bi-arrow-repeat me-1"></i> Renew eligible items (<%= renewable_count %>)
          <% end %>
        <% end %>
    <% else %>
      <button disabled class="btn btn-sm"><i class="bi bi-arrow-repeat me-1"></i> Renewals blocked</button>
    <% end %>
  <% else %>
    <button disabled class="btn btn-sm"><i class="bi bi-arrow-repeat me-1"></i> Nothing is eligible to renew</button>
  <% end %>
</div>
