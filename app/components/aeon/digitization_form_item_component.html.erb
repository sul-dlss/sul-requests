<div data-controller="selected-item-form" data-save-for-later-target="selectedItem" data-action="input->selected-item-form#updateStatus" class="accordion-item mb-4" data-content-id="<%= dom_id %>">
  <div class="digitization-header">
    <div class="accordion-header d-flex flex-nowrap align-items-center position-relative">
      <%= tag.button(
          "",
          type: "button",
          class: "accordion-button accordion-toggle-overlay",
          data: { bs_toggle: "collapse", bs_target: "#content_#{dom_id}" },
          aria: { expanded: !accordion?, controls: "content_#{dom_id}", labelledby: "title_#{dom_id}" },
          disabled: !accordion?
      ) %>
      <div class="d-flex flex-column flex-lg-row align-items-lg-center flex-grow-1 justify-content-lg-between">
        <div class="d-flex align-items-center">
          <i class="bi bi-check2 selected-item-status"></i>
          <span id="title_<%= dom_id %> digitization-title" class="text-wrap">
            <span class="text-black fw-semibold selected-item-title"><%= title %></span>
          </span>
        </div>
      </div>
      <i class="bi bi-chevron-down accordion-header-icon ms-auto px-4"></i>
    </div>
    <%= render Aeon::SelectedItemsActionsComponent.new(dom_id:, save_for_later: object.nil?, title:) %>
  </div>
  <div id="content_<%= dom_id %>" class="accordion-collapse <%= 'collapse' if accordion? %>">
    <%= fields_for base_name, object do |f| %>
      <div class="accordion-body">
        <div class="mb-4">
          <%= f.label :requested_pages, 'Requested pages or instructions', class: 'form-label fw-semibold redesign-required-label' %>
          <%= f.text_field :requested_pages, placeholder: 'e.g. 100-150, 167, 170-180 or Chapter 5', class: 'form-control', data: { 'required-for-submit': true } %>
        </div>

        <div class="mb-4">
          <fieldset>
            <legend class="form-label fs-6 mb-1 fw-semibold">Is this for publication or distribution?</legend>
            <span class="me-3">
              <%= f.radio_button :for_publication, true %>
              <%= f.label :for_publication_true, 'Yes' %>
            </span>

            <%= f.radio_button :for_publication, false %>
            <%= f.label :for_publication_false, 'No' %>
          </fieldset>
        </div>

        <div class="mb-4" data-save-for-later-target="additionalInformation" data-controller="char-counter">
          <%= f.label :additional_information, class: 'form-label fw-semibold' %>
          <%= f.text_area :additional_information, class: 'form-control', maxlength: 255, data: { action: "input->char-counter#updateCharCounter"} %>
          <p class="form-text text-secondary d-flex justify-content-between">
            <span>Limit 255 characters.</span>
            <span data-char-counter-target="counter"></span>
          </p>
        </div>

        <div class="d-flex justify-content-end">
          <button class="next-item btn btn-sm btn-primary" data-selected-item-form-target="nextButton" data-action="selected-item-form#nextItem">Next item</button>
        </div>
      </div>
    <% end %>
  </div>
</div>
