<%= tag.li class: ['position-relative', dom_id(appointment, :option)], data: @data.merge('sort-key' => appointment.sort_key.to_s, value: appointment.id) do %>
  <%= button_tag(class: 'dropdown-item p-0 ps-4 pe-2 py-2 my-1', data: { action: data_action }, disabled: at_limit?) do %>
      <span class="label-value">
        <%= render AppointmentTimeRangeComponent.new(appointment:) %>
        <span class="badge rounded-pill text-bg-light fw-normal d-none d-sm-inline-block ms-1 me-auto" data-count="<%= appointment.requests.length %>" data-appointment-id="<%= appointment.id %>">
          <%= pluralize(appointment.requests.length, 'item') %>
        </span>
      </span>
  <% end %>
<% end %>
