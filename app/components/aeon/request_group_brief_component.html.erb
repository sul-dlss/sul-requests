<div class="request-group border rounded" data-controller="empty-remove">
  <div class="card-body">
    <div class="metadata">
      <%= render Aeon::RequestGroupHeaderComponent.new(title:, base_callnumber:, reading_room: requests.first.reading_room) %>
      <ul class="list-group list-group-flush">
        <% requests.each do |request| %>
          <li id="<%= dom_id(request) %>" class="request list-group-item px-0 <%= "request-status-#{request.status}" %>" data-empty-remove-target="item">
            <div class="d-flex flex-row align-items-center justify-content-between">
              <div class="d-flex gap-3">
                <%= render Aeon::RequestItemIdentifierComponent.new(request:) %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
