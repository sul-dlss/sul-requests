<div class="request-group border rounded p-3 mb-3" data-controller="empty-remove">
  <div class="card-body">
    <div class="metadata">
      <div class="reading-room mb-2 text-dark-emphasis"><%= requests.first.reading_room&.name %></div>
      <%= title_tag %>
      <div class="d-flex gap-sm-3 flex-sm-row flex-wrap flex-column">
        <% if ead_number %>
          <div>Call number: <%= ead_number %></div>
        <% elsif call_number.present? %>
          <div>Call number: <%= call_number %></div>
        <% end %>
      </div>
      <ul class="list-group list-group-flush">
        <% requests.each do |request| %>
          <li id="<%= dom_id(request) %>" class="request list-group-item px-0 <%= "request-status-#{request.status}" %>" data-empty-remove-target="item" data-request-id="<%= request.id %>">
            <div class="d-flex flex-row align-items-center justify-content-between">
              <div class="d-flex gap-3">
                <%= render Aeon::RequestItemIdentifierComponent.new(request:) %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
