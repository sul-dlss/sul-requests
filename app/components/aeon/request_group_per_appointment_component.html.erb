<div id="<%= request_group.dom_id %>_<%= group_id %>" class="request-group request-group-per-appointment <%= classes.join(' ') %>">
  <div class="metadata">
    <h3 class="h4 d-inline">
      <%= request_group.title %>
      <% if request_group.saved_for_later_requests.any? %>
        <span class="text-warning ms-2"><i class="bi bi-exclamation-triangle me-1"></i>Saved for later</span>
      <% end %>
    </h3>
    <span class="ms-2">Call number: <%= request_group.base_callnumber %></span>
    <ul class="list-unstyled mb-0 mt-2">
      <%= render Aeon::RequestGroupItemComponent.with_collection(requests, classes: [], actions: false, remove_from_appointment: true, fulfillment: false, footer: false) %>
    </ul>
  </div>
</div>
