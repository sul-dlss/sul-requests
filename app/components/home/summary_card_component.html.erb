<%= render Home::FlatCardComponent.new(id: id, classes: classes) do |c| %>
  <% c.with_title do %>
    <%= icon %>
  <% end %>

  <% if status? %>
    <% c.with_actions do %>
      <%= status %>
    <% end %>
  <% end %>

  <% c.with_body(classes: %w[pt-1]) do %>
    <h2 class="mb-1"><%= title %></h2>
    <p class="mb-1">
      <%= label %>
      <% if secondary_label.present? %>
        <i class="bi bi-dot"></i>
        <%= secondary_label %>
      <% end %>
    </p>
    <%= render Home::ArrowLinkComponent.new(label: link_label, path: path, classes: ['stretched-link']) if path %>
  <% end %>
<% end %>
