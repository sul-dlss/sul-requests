<%= render CardComponent.new(element: 'li') do |c| %>
  <% c.with_title do %>
    <div class="d-flex flex-row gap-4 align-items-center">
      <span class="small fw-medium rounded-pill text-white bg-plum-light">
        <%= checkout.status_label %>
      </span>
      <span class="small">Payment cannot be processed until item is returned</span>
    </div>
  <% end %>
  <% if accruing_rate_label %>
    <% c.with_actions do %>
      <span class="small fw-medium rounded-pill text-white bg-danger">
        <%= sul_icon 'sharp-warning-24px' %>
        <%= accruing_rate_label %>
      </span>
    <% end %>
  <% end %>
  <% c.with_body(classes: 'bg-white') do %>
    <h2><%= checkout.title %></h2>
  <% end %>
  <% c.with_footer do %>
    <span>Barcode: <%= checkout.barcode %></span>
  <% end %>
<% end %>
