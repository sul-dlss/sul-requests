<%= form_with(model: request, data: { turbo: true, controller: 'appointment-select-submit'}) do |f| %>
  <%= hidden_field_tag 'sidebar', true %>
  <%= f.hidden_field :appointment_id, data: { appointment_select_submit_target: "input" } %>
  <%= render 'aeon_appointments/dropdown', appointments: selectable_appointments, reading_room_id: request.reading_room.id %>
<% end %>
