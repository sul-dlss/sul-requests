<%= tag.div id: "#{id}-accordion", class: %w[accordion-item my-4 shadow-sm].append("accordion-step-#{step_index}").concat(@classes), data: data.merge('accordion-form-target': 'accordion') do %>
  <div class="accordion-header d-flex p-2">
    <button class="accordion-button p-0" type="button" data-bs-toggle="collapse" data-bs-target="#<%= id %>" aria-expanded="<%= expanded? ? 'true' : 'false' %>" aria-controls="<%= id %>" disabled>
      <div class="step-number d-flex justify-content-center align-items-center rounded-circle p-2 me-2 text-white"><%= step_index %></div>
      <h2 class="accordion-title fw-semibold fs-5 mb-0">
        <%= title %>
      </h2>
    </button>
    <button class="btn btn-link edit-button align-items-center" data-action="click->accordion-form#editStep analytics#send" data-analytics-category-param="Accordion" data-analytics-action-param="Edit" aria-controls="<%= id %>">
      <i class="bi bi-pencil me-1"></i> Edit
    </button>
  </div>

  <% if body? %>
    <div id="<%= id %>" data-action="input->accordion-form#enableNextButton"  class="accordion-collapse collapse <%= 'show' if expanded? %>" data-bs-parent="#<%= form_id %>">
      <div class="accordion-body">
        <%= body %>

        <% if submit? %>
          <% spinner = capture do %>
            <%= tag.span(class: 'spinner-border spinner-border-sm me-2', aria: { hidden: true }) %><%= submit_text %>
          <% end %>
          <div class="mt-3 form-group d-flex flex-wrap justify-content-end gap-1">
            <%= footer %>
            <span>
              <%= tag.button class: 'btn btn-primary', type: 'submit', data: { 'turbo-submits-with': spinner, 'next-step-button': true, action: 'analytics#send', 'analytics-category-param': 'Request', 'analytics-action-param': 'Submit' } do %>
                <%= submit_text %>
              <% end %>
            </span>
          </div>
        <% else %>
          <div class="mt-3 d-flex justify-content-end gap-1">
            <%= footer %>
            <button class="btn btn-primary" type="button" data-action="click->accordion-form#nextStep analytics#send" data-analytics-category-param="Accordion" data-analytics-action-param="Continue" data-next-step-button="true">Continue</button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
