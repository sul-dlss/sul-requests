<div role="alert" class="<%= classes.join(' ') %> d-flex shadow-sm align-items-center">
  <% if with_icon %>
    <div role="img" aria-label="<%= aria_label %>" class="<%= icon_class %> fs-3 me-3 align-self-center d-flex justify-content-center"></div>
  <% end %>
  <div class="text-body">
    <div><%= content %></div>
  </div>
</div>
